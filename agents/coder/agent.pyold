# ============================================================================
# CONFIGURATION DES IMPORTS (TRÈS IMPORTANT)
# ============================================================================

# Ajouter le chemin racine du projet pour pouvoir importer BaseAgent
project_root = Path(__file__).parent.parent.parent
sys.path.insert(0, str(project_root))

# ⚠️ IMPORT ABSOLU - C'EST LA CLÉ !
from agents.base_agent.base_agent import BaseAgent, AgentStatus, Message

logger = logging.getLogger(__name__)


# ============================================================================
# CLASSES DE DONNÉES (définies dans le même fichier)
# ============================================================================

class CodeLanguage(Enum):
    """Langages de programmation supportés"""
    PYTHON = "python"
    JAVASCRIPT = "javascript"
    TYPESCRIPT = "typescript"
    SOLIDITY = "solidity"
    RUST = "rust"
    GO = "go"
    JAVA = "java"
    CSHARP = "csharp"


class Framework(Enum):
    """Frameworks supportés"""
    FASTAPI = "fastapi"
    EXPRESS = "express"
    NEXTJS = "nextjs"
    REACT = "react"
    VUE = "vue"
    HARDHAT = "hardhat"
    ANCHOR = "anchor"
    FOUNDRY = "foundry"
    DJANGO = "django"
    SPRING = "spring"


class ComponentType(Enum):
    """Types de composants logiciels"""
    BACKEND_SERVICE = "backend_service"
    FRONTEND_APP = "frontend_application"
    SMART_CONTRACT = "smart_contract"
    DATABASE = "database"
    API_GATEWAY = "api_gateway"
    DEVOPS = "devops"
    TEST_SUITE = "test_suite"
    DOCUMENTATION = "documentation"


class GenerationStatus(Enum):
    """Statuts de génération de code"""
    PENDING = "pending"
    GENERATING = "generating"
    COMPLETED = "completed"
    FAILED = "failed"
    VALIDATING = "validating"


@dataclass
class CodeComponent:
    """Représente un composant de code à générer"""
    id: str
    name: str
    component_type: ComponentType
    language: CodeLanguage
    framework: Optional[Framework] = None
    description: str = ""
    dependencies: List[str] = field(default_factory=list)
    output_path: Optional[Path] = None
    config: Dict[str, Any] = field(default_factory=dict)
    status: GenerationStatus = GenerationStatus.PENDING
    created_at: datetime = field(default_factory=datetime.now)
    updated_at: datetime = field(default_factory=datetime.now)
    
    def to_dict(self) -> Dict[str, Any]:
        """Convertit en dictionnaire"""
        return {
            "id": self.id,
            "name": self.name,
            "component_type": self.component_type.value,
            "language": self.language.value,
            "framework": self.framework.value if self.framework else None,
            "description": self.description,
            "dependencies": self.dependencies,
            "output_path": str(self.output_path) if self.output_path else None,
            "config": self.config,
            "status": self.status.value,
            "created_at": self.created_at.isoformat(),
            "updated_at": self.updated_at.isoformat()
        }
    
    @classmethod
    def from_dict(cls, data: Dict[str, Any]) -> 'CodeComponent':
        """Crée une instance depuis un dictionnaire"""
        data = data.copy()
        data['component_type'] = ComponentType(data['component_type'])
        data['language'] = CodeLanguage(data['language'])
        if data.get('framework'):
            data['framework'] = Framework(data['framework'])
        if data.get('output_path'):
            data['output_path'] = Path(data['output_path'])
        data['status'] = GenerationStatus(data.get('status', 'pending'))
        if data.get('created_at'):
            data['created_at'] = datetime.fromisoformat(data['created_at'])
        if data.get('updated_at'):
            data['updated_at'] = datetime.fromisoformat(data['updated_at'])
        return cls(**data)


@dataclass
class GeneratedFile:
    """Représente un fichier généré"""
    path: Path
    content: str
    language: CodeLanguage
    size_bytes: int
    line_count: int
    generated_at: datetime = field(default_factory=datetime.now)
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "path": str(self.path),
            "language": self.language.value,
            "size_bytes": self.size_bytes,
            "line_count": self.line_count,
            "generated_at": self.generated_at.isoformat()
        }


@dataclass
class GenerationResult:
    """Résultat de la génération de code"""
    success: bool
    component_id: str
    component_name: str
    output_path: Path
    files_created: List[GeneratedFile] = field(default_factory=list)
    errors: List[str] = field(default_factory=list)
    warnings: List[str] = field(default_factory=list)
    validation_results: Dict[str, Any] = field(default_factory=dict)
    timestamp: datetime = field(default_factory=datetime.now)
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "success": self.success,
            "component_id": self.component_id,
            "component_name": self.component_name,
            "output_path": str(self.output_path),
            "files_created": [f.to_dict() for f in self.files_created],
            "errors": self.errors,
            "warnings": self.warnings,
            "validation_results": self.validation_results,
            "timestamp": self.timestamp.isoformat()
        }


# ============================================================================
# AGENT CODER PRINCIPAL (structure identique à Tester)
# ============================================================================

class CoderAgent(BaseAgent):
    """
    Agent responsable du développement complet du code.
    
    Capacités:
    - Génération de code multi-langages (Python, JS, Solidity, Rust, Go)
    - Création d'APIs REST, GraphQL et WebSocket
    - Développement frontend React/Vue/Next.js
    - Génération de smart contracts (ERC20, ERC721, ERC1155)
    - Tests unitaires, d'intégration et E2E
    - Documentation automatique (README, JSDoc, NatSpec)
    - Configuration DevOps (Docker, K8s, CI/CD)
    - Validation et linting automatique
    """
    
    def __init__(self, config_path: Optional[str] = None):
        """
        Initialise l'agent Coder.
        
        Args:
            config_path: Chemin vers le fichier de configuration
        """
        # Déterminer le chemin de configuration
        if config_path is None:
            config_path = str(project_root / "agents" / "coder" / "config.yaml")
        
        # Initialiser l'agent de base
        super().__init__(config_path)
        
        # Configuration par défaut si nécessaire
        if not self._agent_config:
            self._agent_config = self._get_default_config()
        
        # Configuration spécifique au Coder
        self._coder_config = self._agent_config.get('coder', {})
        
        # État interne
        self.components: Dict[str, CodeComponent] = {}
        self.generation_results: Dict[str, GenerationResult] = {}
        self.code_templates: Dict[str, str] = {}
        self.framework_configs: Dict[str, Any] = {}
        self._components: Dict[str, Any] = {}
        self._initialized = False
        
        # Statistiques
        self.stats = {
            'total_components': 0,
            'total_generations': 0,
            'successful_generations': 0,
            'failed_generations': 0,
            'total_files_created': 0,
            'total_lines_of_code': 0,
            'languages_used': {},
            'frameworks_used': {},
            'average_generation_time_ms': 0,
            'last_generation': None
        }
        
        # Initialiser les templates
        self._initialize_templates()
        
        self._logger.info(f"✅ Agent Coder créé (config: {config_path})")
    
    def _get_default_config(self) -> Dict[str, Any]:
        """Configuration par défaut (si pas de fichier config.yaml)"""
        return {
            "agent": {
                "name": "CoderAgent",
                "display_name": "Développeur Principal",
                "version": "2.2.0",
                "description": "Agent responsable du développement complet du code",
                "capabilities": [
                    "generate_backend_code",
                    "generate_frontend_code",
                    "generate_smart_contracts",
                    "generate_tests",
                    "generate_documentation",
                    "generate_devops",
                    "code_validation",
                    "multi_language_support"
                ]
            },
            "coder": {
                "default_language": "python",
                "default_framework": "fastapi",
                "output_directory": "./generated_code",
                "templates_directory": "./templates",
                "max_file_size_kb": 500,
                "enable_validation": True,
                "enable_linting": True,
                "enable_formatting": True,
                "auto_install_deps": False
            },
            "languages": {
                "python": {
                    "enabled": True,
                    "formatter": "black",
                    "linter": "pylint",
                    "test_framework": "pytest"
                },
                "javascript": {
                    "enabled": True,
                    "formatter": "prettier",
                    "linter": "eslint",
                    "test_framework": "jest"
                },
                "solidity": {
                    "enabled": True,
                    "formatter": "prettier-plugin-solidity",
                    "linter": "solhint",
                    "test_framework": "hardhat"
                },
                "rust": {
                    "enabled": False,
                    "formatter": "rustfmt",
                    "linter": "clippy",
                    "test_framework": "cargo-test"
                },
                "go": {
                    "enabled": False,
                    "formatter": "gofmt",
                    "linter": "golint",
                    "test_framework": "go-test"
                }
            }
        }
    
    def _initialize_templates(self):
        """Initialise les templates de code."""
        self.code_templates = {
            # Templates Python
            "python_fastapi_service": self._get_fastapi_template(),
            "python_fastapi_crud": self._get_fastapi_crud_template(),
            "python_database_model": self._get_database_model_template(),
            
            # Templates JavaScript
            "javascript_express_service": self._get_express_template(),
            "javascript_express_api": self._get_express_api_template(),
            
            # Templates React
            "react_component": self._get_react_template(),
            "react_hooks_component": self._get_react_hooks_template(),
            
            # Templates Solidity
            "solidity_contract": self._get_solidity_template(),
            "solidity_erc20": self._get_erc20_template(),
            "solidity_erc721": self._get_erc721_template(),
            
            # Templates DevOps
            "docker_compose": self._get_docker_compose_template(),
            "dockerfile": self._get_dockerfile_template(),
            "github_actions": self._get_github_actions_template(),
            "kubernetes_deployment": self._get_kubernetes_template(),
            
            # Templates divers
            "readme": self._get_readme_template(),
            "gitignore": self._get_gitignore_template(),
            "license": self._get_license_template()
        }
        
        self._logger.debug(f"📦 {len(self.code_templates)} templates initialisés")
    
    # ========================================================================
    # MÉTHODES D'INITIALISATION
    # ========================================================================
    
    async def initialize(self) -> bool:
        """
        Initialise l'agent Coder.
        
        Returns:
            True si l'initialisation a réussi
        """
        try:
            self._set_status(AgentStatus.INITIALIZING)
            self._logger.info("Initialisation de l'agent Coder...")
            
            # Initialiser les composants
            await self._initialize_components()
            
            # Charger les configurations des frameworks
            await self._load_framework_configs()
            
            # Vérifier les dépendances
            await self._check_dependencies()
            
            result = await super().initialize()
            
            if result:
                self._set_status(AgentStatus.READY)
                self._initialized = True
                self._logger.info("✅ Agent Coder prêt")
            
            return result
            
        except Exception as e:
            self._logger.error(f"❌ Erreur initialisation: {e}")
            self._logger.error(traceback.format_exc())
            self._set_status(AgentStatus.ERROR)
            return False
    
    async def _initialize_components(self) -> bool:
        """
        Initialise les composants internes.
        
        Returns:
            True si l'initialisation a réussi
        """
        try:
            self._logger.info("Initialisation des composants...")
            
            self._components = {
                "code_generator": {
                    "enabled": True,
                    "languages": ["python", "javascript", "solidity", "rust", "go"],
                    "templates_loaded": len(self.code_templates)
                },
                "template_manager": {
                    "enabled": True,
                    "templates": list(self.code_templates.keys())
                },
                "code_validator": {
                    "enabled": self._coder_config.get("enable_validation", True),
                    "languages": ["python", "javascript", "solidity"]
                },
                "file_writer": {
                    "enabled": True,
                    "output_dir": str(self._get_output_directory())
                },
                "dependency_manager": {
                    "enabled": self._coder_config.get("auto_install_deps", False),
                    "managed_deps": []
                },
                "documentation_generator": {
                    "enabled": True,
                    "formats": ["markdown", "html", "pdf"]
                }
            }
            
            self._logger.info(f"✅ Composants: {list(self._components.keys())}")
            return True
            
        except Exception as e:
            self._logger.error(f"Erreur composants: {e}")
            return False
    
    async def _check_dependencies(self) -> bool:
        """Vérifie les dépendances optionnelles."""
        self._logger.info("Vérification des dépendances...")
        
        dependencies = {
            "black": "formateur Python",
            "pylint": "linter Python",
            "eslint": "linter JavaScript",
            "prettier": "formateur code",
            "solc": "compilateur Solidity",
            "rustc": "compilateur Rust",
            "go": "compilateur Go"
        }
        
        available = []
        missing = []
        
        for dep, description in dependencies.items():
            try:
                import shutil
                if shutil.which(dep):
                    available.append(dep)
                else:
                    missing.append(f"{dep} ({description})")
            except:
                missing.append(f"{dep} ({description})")
        
        if available:
            self._logger.info(f"   ✅ Dépendances disponibles: {', '.join(available)}")
        if missing:
            self._logger.warning(f"   ⚠️ Dépendances manquantes: {', '.join(missing[:3])}")
            if len(missing) > 3:
                self._logger.warning(f"      ... et {len(missing)-3} autres")
        
        return True
    
    async def _load_framework_configs(self):
        """Charge les configurations des frameworks supportés."""
        self._logger.info("Chargement des configurations des frameworks...")
        
        config_dir = project_root / "agents" / "coder" / "frameworks"
        
        if config_dir.exists():
            loaded = 0
            for config_file in config_dir.glob("*.yaml"):
                try:
                    with open(config_file, 'r', encoding='utf-8') as f:
                        framework_config = yaml.safe_load(f)
                        framework_name = config_file.stem
                        self.framework_configs[framework_name] = framework_config
                        loaded += 1
                        self._logger.debug(f"   ✓ {framework_name}")
                except Exception as e:
                    self._logger.warning(f"   ⚠️ Erreur chargement {config_file.name}: {e}")
            
            self._logger.info(f"   ✅ {loaded} configurations chargées")
        else:
            self._logger.debug("   ℹ️ Aucun répertoire de frameworks")
    
    # ========================================================================
    # MÉTHODES DE GESTION D'ÉTAT
    # ========================================================================
    
    async def shutdown(self) -> bool:
        """
        Arrête l'agent proprement.
        """
        self._logger.info("Arrêt de l'agent Coder...")
        self._set_status(AgentStatus.SHUTDOWN)
        
        # Sauvegarder les statistiques
        try:
            output_dir = self._get_output_directory()
            stats_file = output_dir / "coder_stats.json"
            with open(stats_file, 'w', encoding='utf-8') as f:
                json.dump({
                    "stats": self.stats,
                    "components": len(self.components),
                    "generations": len(self.generation_results),
                    "timestamp": datetime.now().isoformat()
                }, f, indent=2)
            self._logger.info(f"   ✓ Statistiques sauvegardées")
        except Exception as e:
            self._logger.warning(f"   ⚠️ Impossible de sauvegarder: {e}")
        
        self._logger.info("✅ Agent Coder arrêté")
        return True
    
    async def pause(self) -> bool:
        """Met l'agent en pause."""
        self._logger.info("Pause de l'agent Coder...")
        self._set_status(AgentStatus.PAUSED)
        return True
    
    async def resume(self) -> bool:
        """Reprend l'activité."""
        self._logger.info("Reprise de l'agent Coder...")
        self._set_status(AgentStatus.READY)
        return True
    
    async def health_check(self) -> Dict[str, Any]:
        """
        Vérifie la santé de l'agent.
        """
        return {
            "agent": self.name,
            "status": self._status.value if hasattr(self._status, 'value') else str(self._status),
            "ready": self._status == AgentStatus.READY,
            "initialized": self._initialized,
            "components": list(self._components.keys()),
            "templates_loaded": len(self.code_templates),
            "stats": {
                "total_generations": self.stats['total_generations'],
                "successful": self.stats['successful_generations'],
                "failed": self.stats['failed_generations'],
                "files_created": self.stats['total_files_created'],
                "lines_of_code": self.stats['total_lines_of_code']
            },
            "last_generation": self.stats['last_generation'],
            "timestamp": datetime.now().isoformat()
        }
    
    def get_agent_info(self) -> Dict[str, Any]:
        """
        Retourne les informations de l'agent.
        """
        return {
            "id": self.name,
            "name": "CoderAgent",
            "display_name": "Développeur Principal",
            "version": self._agent_config.get("agent", {}).get("version", "2.2.0"),
            "status": self._status.value if hasattr(self._status, 'value') else str(self._status),
            "capabilities": self._agent_config.get("agent", {}).get("capabilities", []),
            "languages": [lang.value for lang in CodeLanguage],
            "frameworks": [fw.value for fw in Framework],
            "templates": list(self.code_templates.keys()),
            "stats": self.stats
        }
    
    # ========================================================================
    # GESTION DES MESSAGES
    # ========================================================================
    
    async def _handle_custom_message(self, message: Message) -> Optional[Message]:
        """
        Gère les messages personnalisés.
        
        Args:
            message: Message reçu
            
        Returns:
            Réponse ou None
        """
        try:
            msg_type = message.message_type
            self._logger.debug(f"Message reçu: {msg_type}")
            
            if msg_type == "generate_code":
                # Générer du code
                plan = message.content.get("plan", {})
                result = await self.generate_code(plan)
                
                return Message(
                    sender=self.name,
                    recipient=message.sender,
                    content=result,
                    message_type="generation_result",
                    correlation_id=message.message_id
                )
            
            elif msg_type == "validate_code":
                # Valider du code
                code = message.content.get("code", "")
                language = message.content.get("language", "python")
                result = await self.validate_code(code, language)
                
                return Message(
                    sender=self.name,
                    recipient=message.sender,
                    content=result,
                    message_type="validation_result",
                    correlation_id=message.message_id
                )
            
            elif msg_type == "get_template":
                # Obtenir un template spécifique
                template_name = message.content.get("template", "")
                if template_name in self.code_templates:
                    return Message(
                        sender=self.name,
                        recipient=message.sender,
                        content={"template": self.code_templates[template_name]},
                        message_type="template_response",
                        correlation_id=message.message_id
                    )
                else:
                    return Message(
                        sender=self.name,
                        recipient=message.sender,
                        content={"error": f"Template '{template_name}' not found"},
                        message_type="error",
                        correlation_id=message.message_id
                    )
            
            elif msg_type == "list_templates":
                # Lister les templates disponibles
                return Message(
                    sender=self.name,
                    recipient=message.sender,
                    content={"templates": list(self.code_templates.keys())},
                    message_type="templates_list",
                    correlation_id=message.message_id
                )
            
            elif msg_type == "get_stats":
                # Retourner les statistiques
                return Message(
                    sender=self.name,
                    recipient=message.sender,
                    content={"stats": self.stats},
                    message_type="stats_response",
                    correlation_id=message.message_id
                )
            
            elif msg_type == "pause":
                await self.pause()
                return Message(
                    sender=self.name,
                    recipient=message.sender,
                    content={"status": "paused"},
                    message_type="status_update",
                    correlation_id=message.message_id
                )
            
            elif msg_type == "resume":
                await self.resume()
                return Message(
                    sender=self.name,
                    recipient=message.sender,
                    content={"status": "resumed"},
                    message_type="status_update",
                    correlation_id=message.message_id
                )
            
            elif msg_type == "shutdown":
                await self.shutdown()
                return Message(
                    sender=self.name,
                    recipient=message.sender,
                    content={"status": "shutdown"},
                    message_type="status_update",
                    correlation_id=message.message_id
                )
            
            # Si le type de message n'est pas reconnu
            self._logger.warning(f"Type de message non supporté: {msg_type}")
            return None
            
        except Exception as e:
            self._logger.error(f"Erreur traitement message: {e}")
            return Message(
                sender=self.name,
                recipient=message.sender,
                content={"error": str(e)},
                message_type="error",
                correlation_id=message.message_id
            )
    
    # ========================================================================
    # MÉTHODES FONCTIONNELLES PRINCIPALES
    # ========================================================================
    
    async def generate_code(self, plan: Dict[str, Any]) -> Dict[str, Any]:
        """
        Génère du code selon le plan d'implémentation.
        
        Args:
            plan: Plan d'implémentation
            
        Returns:
            Résultats de la génération
        """
        self._logger.info(f"🚀 Génération de code pour {plan.get('project', 'projet inconnu')}")
        
        try:
            # Valider le plan
            validation = self._validate_plan(plan)
            if not validation["valid"]:
                return {
                    "success": False,
                    "error": validation["error"],
                    "components_generated": 0
                }
            
            # Créer les composants
            components = self._create_components_from_plan(plan)
            self._logger.info(f"   📦 {len(components)} composant(s) à générer")
            
            # Générer chaque composant
            results = []
            total_files = 0
            total_lines = 0
            
            for component in components:
                self._logger.info(f"   🔨 Génération: {component.name}")
                result = await self._generate_component(component)
                results.append(result)
                
                # Mettre à jour les stats
                self.generation_results[component.id] = result
                if result.success:
                    total_files += len(result.files_created)
                    for file in result.files_created:
                        total_lines += file.line_count
                    
                    # Statistiques par langage
                    lang = component.language.value
                    self.stats['languages_used'][lang] = self.stats['languages_used'].get(lang, 0) + 1
                    
                    if component.framework:
                        framework = component.framework.value
                        self.stats['frameworks_used'][framework] = self.stats['frameworks_used'].get(framework, 0) + 1
            
            # Mettre à jour les statistiques globales
            self.stats['total_generations'] += 1
            successful = sum(1 for r in results if r.success)
            self.stats['successful_generations'] += successful
            self.stats['failed_generations'] += (len(results) - successful)
            self.stats['total_files_created'] += total_files
            self.stats['total_lines_of_code'] += total_lines
            self.stats['last_generation'] = datetime.now().isoformat()
            
            # Résultat global
            success = all(r.success for r in results)
            
            return {
                "success": success,
                "project": plan.get('project', 'unknown'),
                "total_components": len(results),
                "successful_components": successful,
                "failed_components": [r.component_name for r in results if not r.success],
                "total_files_created": total_files,
                "total_lines_of_code": total_lines,
                "output_directory": str(self._get_output_directory()),
                "results": [r.to_dict() for r in results]
            }
            
        except Exception as e:
            self._logger.error(f"Erreur génération: {e}")
            self._logger.error(traceback.format_exc())
            return {
                "success": False,
                "error": str(e),
                "components_generated": 0
            }
    
    def _validate_plan(self, plan: Dict[str, Any]) -> Dict[str, Any]:
        """Valide le plan d'implémentation."""
        required_fields = ['components']
        
        for field in required_fields:
            if field not in plan:
                return {"valid": False, "error": f"Champ manquant: {field}"}
        
        if not isinstance(plan['components'], list):
            return {"valid": False, "error": "components doit être une liste"}
        
        if len(plan['components']) == 0:
            return {"valid": False, "error": "Aucun composant spécifié"}
        
        return {"valid": True}
    
    def _create_components_from_plan(self, plan: Dict[str, Any]) -> List[CodeComponent]:
        """Crée les composants depuis le plan."""
        components = []
        
        for i, comp_data in enumerate(plan.get('components', [])):
            try:
                # Générer un ID unique
                comp_id = f"comp_{datetime.now().strftime('%Y%m%d_%H%M%S')}_{i}"
                
                # Nom
                name = comp_data.get('name', f"component_{i+1}")
                
                # Type avec fallback
                type_str = comp_data.get('type', 'backend_service')
                try:
                    component_type = ComponentType(type_str)
                except ValueError:
                    self._logger.warning(f"   ⚠️ Type inconnu '{type_str}', utilisation backend_service")
                    component_type = ComponentType.BACKEND_SERVICE
                
                # Langage avec fallback
                lang_str = comp_data.get('language', 'python')
                try:
                    language = CodeLanguage(lang_str)
                except ValueError:
                    self._logger.warning(f"   ⚠️ Langage inconnu '{lang_str}', utilisation python")
                    language = CodeLanguage.PYTHON
                
                # Framework optionnel
                framework = None
                if comp_data.get('framework'):
                    try:
                        framework = Framework(comp_data['framework'])
                    except ValueError:
                        self._logger.warning(f"   ⚠️ Framework inconnu '{comp_data['framework']}'")
                
                # Chemin de sortie
                output_path = None
                if comp_data.get('output_path'):
                    output_path = Path(comp_data['output_path'])
                
                component = CodeComponent(
                    id=comp_id,
                    name=name,
                    component_type=component_type,
                    language=language,
                    framework=framework,
                    description=comp_data.get('description', ''),
                    dependencies=comp_data.get('dependencies', []),
                    output_path=output_path,
                    config=comp_data.get('config', {})
                )
                components.append(component)
                self.components[comp_id] = component
                
            except Exception as e:
                self._logger.warning(f"   ⚠️ Erreur création composant {comp_data.get('name', 'inconnu')}: {e}")
        
        return components
    
    async def _generate_component(self, component: CodeComponent) -> GenerationResult:
        """Génère un composant spécifique."""
        try:
            # Mettre à jour le statut
            component.status = GenerationStatus.GENERATING
            component.updated_at = datetime.now()
            
            # Créer le dossier de sortie
            output_dir = component.output_path or self._get_output_directory() / component.name
            output_dir.mkdir(parents=True, exist_ok=True)
            
            # Sélectionner le template
            template = self._select_template(component)
            
            if not template:
                component.status = GenerationStatus.FAILED
                return GenerationResult(
                    success=False,
                    component_id=component.id,
                    component_name=component.name,
                    output_path=output_dir,
                    errors=[f"Template non trouvé pour {component.language.value}/{component.component_type.value}"]
                )
            
            # Remplir le template
            rendered_code = self._render_template(template, component)
            
            # Déterminer le nom du fichier
            filename = self._get_filename(component)
            filepath = output_dir / filename
            
            # Compter les lignes
            lines = rendered_code.count('\n') + 1
            
            # Écrire le fichier
            with open(filepath, 'w', encoding='utf-8') as f:
                f.write(rendered_code)
            
            # Créer l'objet fichier généré
            generated_file = GeneratedFile(
                path=filepath,
                content=rendered_code,
                language=component.language,
                size_bytes=len(rendered_code.encode('utf-8')),
                line_count=lines
            )
            
            # Générer les fichiers additionnels
            additional_files = await self._generate_additional_files(component, output_dir)
            
            all_files = [generated_file] + additional_files
            
            # Valider si activé
            validation = {}
            warnings = []
            if self._coder_config.get("enable_validation", True):
                validation = await self._validate_generated_code(rendered_code, component.language)
                if not validation.get("valid", True):
                    warnings.extend(validation.get("warnings", []))
            
            # Mettre à jour le statut
            component.status = GenerationStatus.COMPLETED
            component.updated_at = datetime.now()
            
            return GenerationResult(
                success=True,
                component_id=component.id,
                component_name=component.name,
                output_path=output_dir,
                files_created=all_files,
                warnings=warnings,
                validation_results=validation
            )
            
        except Exception as e:
            component.status = GenerationStatus.FAILED
            component.updated_at = datetime.now()
            self._logger.error(f"   ❌ Erreur génération {component.name}: {e}")
            
            return GenerationResult(
                success=False,
                component_id=component.id,
                component_name=component.name,
                output_path=Path(),
                errors=[str(e)]
            )
    
    async def _generate_additional_files(self, component: CodeComponent, output_dir: Path) -> List[GeneratedFile]:
        """Génère des fichiers supplémentaires."""
        additional_files = []
        
        # requirements.txt pour Python
        if component.language == CodeLanguage.PYTHON and component.component_type == ComponentType.BACKEND_SERVICE:
            req_content = self._generate_requirements_txt(component)
            req_file = output_dir / "requirements.txt"
            
            with open(req_file, 'w', encoding='utf-8') as f:
                f.write(req_content)
            
            additional_files.append(GeneratedFile(
                path=req_file,
                content=req_content,
                language=CodeLanguage.PYTHON,
                size_bytes=len(req_content.encode('utf-8')),
                line_count=req_content.count('\n') + 1
            ))
        
        # package.json pour JavaScript
        elif component.language == CodeLanguage.JAVASCRIPT:
            pkg_content = self._generate_package_json(component)
            pkg_file = output_dir / "package.json"
            
            with open(pkg_file, 'w', encoding='utf-8') as f:
                f.write(pkg_content)
            
            additional_files.append(GeneratedFile(
                path=pkg_file,
                content=pkg_content,
                language=CodeLanguage.JAVASCRIPT,
                size_bytes=len(pkg_content.encode('utf-8')),
                line_count=pkg_content.count('\n') + 1
            ))
        
        # README.md toujours
        readme_content = self._render_template(self.code_templates.get("readme", ""), component)
        readme_file = output_dir / "README.md"
        
        with open(readme_file, 'w', encoding='utf-8') as f:
            f.write(readme_content)
        
        additional_files.append(GeneratedFile(
            path=readme_file,
            content=readme_content,
            language=CodeLanguage.PYTHON,  # Pas vraiment Python mais pour le comptage
            size_bytes=len(readme_content.encode('utf-8')),
            line_count=readme_content.count('\n') + 1
        ))
        
        # .gitignore
        gitignore_content = self.code_templates.get("gitignore", "")
        gitignore_file = output_dir / ".gitignore"
        
        with open(gitignore_file, 'w', encoding='utf-8') as f:
            f.write(gitignore_content)
        
        additional_files.append(GeneratedFile(
            path=gitignore_file,
            content=gitignore_content,
            language=CodeLanguage.PYTHON,
            size_bytes=len(gitignore_content.encode('utf-8')),
            line_count=gitignore_content.count('\n') + 1
        ))
        
        return additional_files
    
    def _generate_requirements_txt(self, component: CodeComponent) -> str:
        """Génère un fichier requirements.txt."""
        deps = [
            "fastapi>=0.104.0",
            "uvicorn>=0.24.0",
            "pydantic>=2.5.0",
            "python-dotenv>=1.0.0"
        ]
        
        if component.dependencies:
            deps.extend(component.dependencies)
        
        return "# Dépendances Python\n" + "\n".join(deps)
    
    def _generate_package_json(self, component: CodeComponent) -> str:
        """Génère un fichier package.json."""
        pkg = {
            "name": component.name.lower().replace(' ', '-'),
            "version": "1.0.0",
            "description": component.description,
            "main": "index.js",
            "scripts": {
                "start": "node index.js",
                "dev": "nodemon index.js",
                "test": "jest"
            },
            "dependencies": {
                "express": "^4.18.2",
                "cors": "^2.8.5",
                "dotenv": "^16.3.1"
            },
            "devDependencies": {
                "nodemon": "^3.0.1",
                "jest": "^29.7.0"
            }
        }
        
        if component.dependencies:
            for dep in component.dependencies:
                if ':' in dep:
                    name, version = dep.split(':', 1)
                    pkg["dependencies"][name] = version
                else:
                    pkg["dependencies"][dep] = "*"
        
        return json.dumps(pkg, indent=2)
    
    def _select_template(self, component: CodeComponent) -> str:
        """Sélectionne le template approprié."""
        # Essayer avec framework
        if component.framework:
            framework_key = f"{component.language.value}_{component.framework.value}"
            if framework_key in self.code_templates:
                return self.code_templates[framework_key]
        
        # Essayer avec type
        type_key = f"{component.language.value}_{component.component_type.value}"
        if type_key in self.code_templates:
            return self.code_templates[type_key]
        
        # Fallback basique par langage
        if component.language == CodeLanguage.PYTHON:
            return self.code_templates.get("python_fastapi_service", "")
        elif component.language == CodeLanguage.JAVASCRIPT:
            return self.code_templates.get("javascript_express_service", "")
        elif component.language == CodeLanguage.SOLIDITY:
            return self.code_templates.get("solidity_contract", "")
        
        return ""
    
    def _render_template(self, template: str, component: CodeComponent) -> str:
        """Remplit un template avec les données."""
        replacements = {
            "{{ component_name }}": component.name,
            "{{ service_name }}": component.name,
            "{{ contract_name }}": component.name,
            "{{ description }}": component.description,
            "{{ version }}": "1.0.0",
            "{{ author }}": "SmartContractDevPipeline",
            "{{ year }}": str(datetime.now().year),
            "{{ date }}": datetime.now().strftime('%Y-%m-%d'),
            "{{ port }}": str(component.config.get('port', 8000)),
            "{{ solidity_version }}": component.config.get('solidity_version', '0.8.19'),
            "{{ model_name }}": f"{component.name.capitalize()}Model"
        }
        
        result = template
        for key, value in replacements.items():
            result = result.replace(key, value)
        
        return result
    
    def _get_filename(self, component: CodeComponent) -> str:
        """Détermine le nom du fichier principal."""
        extensions = {
            CodeLanguage.PYTHON: ".py",
            CodeLanguage.JAVASCRIPT: ".js",
            CodeLanguage.TYPESCRIPT: ".ts",
            CodeLanguage.SOLIDITY: ".sol",
            CodeLanguage.RUST: ".rs",
            CodeLanguage.GO: ".go",
            CodeLanguage.JAVA: ".java",
            CodeLanguage.CSHARP: ".cs"
        }
        
        ext = extensions.get(component.language, ".txt")
        
        if component.component_type == ComponentType.BACKEND_SERVICE:
            return f"main{ext}" if component.language == CodeLanguage.PYTHON else f"index{ext}"
        elif component.component_type == ComponentType.SMART_CONTRACT:
            return f"{component.name}{ext}"
        elif component.component_type == ComponentType.FRONTEND_APP:
            return f"{component.name}{ext}"
        else:
            return f"{component.name}{ext}"
    
    def _get_output_directory(self) -> Path:
        """Retourne le répertoire de sortie."""
        output_dir = Path(self._coder_config.get("output_directory", "./generated_code"))
        if not output_dir.is_absolute():
            output_dir = project_root / output_dir
        output_dir.mkdir(parents=True, exist_ok=True)
        return output_dir
    
    async def validate_code(self, code: str, language: str = "python") -> Dict[str, Any]:
        """Valide du code."""
        result = {
            "valid": True,
            "errors": [],
            "warnings": []
        }
        
        if not code or len(code.strip()) == 0:
            result["valid"] = False
            result["errors"].append("Code vide")
            return result
        
        # Vérifications basiques par langage
        lines = code.split('\n')
        
        if language == "python":
            # Vérifier la syntaxe
            try:
                compile(code, '<string>', 'exec')
            except SyntaxError as e:
                result["valid"] = False
                result["errors"].append(f"Erreur syntaxe: {e}")
            
            # Vérifier la longueur des lignes
            for i, line in enumerate(lines, 1):
                if len(line) > 79:
                    result["warnings"].append(f"Ligne {i} trop longue ({len(line)} > 79)")
        
        elif language == "solidity":
            if 'pragma solidity' not in code:
                result["warnings"].append("Version pragma manquante")
        
        return result
    
    async def _validate_generated_code(self, code: str, language: CodeLanguage) -> Dict[str, Any]:
        """Valide le code généré."""
        return await self.validate_code(code, language.value)
    
    # ========================================================================
    # TEMPLATES DE CODE
    # ========================================================================
    
    def _get_fastapi_template(self) -> str:
        """Template FastAPI de base."""
        return '''"""
{{ service_name }} - Service FastAPI
{{ description }}
Version: {{ version }}
Author: {{ author }}
Date: {{ date }}
"""

from fastapi import FastAPI, HTTPException, Depends, status
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel, Field
from typing import Optional, List, Dict, Any
from datetime import datetime
import logging

# Configuration logging
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# Création de l'application
app = FastAPI(
    title="{{ service_name }}",
    description="{{ description }}",
    version="{{ version }}"
)

# Configuration CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Modèles
class Item(BaseModel):
    id: Optional[int] = None
    name: str = Field(..., min_length=1, max_length=100)
    description: Optional[str] = None
    created_at: datetime = Field(default_factory=datetime.now)

# Routes
@app.get("/")
async def root():
    return {
        "message": "Hello from {{ service_name }}",
        "version": "{{ version }}",
        "docs": "/docs"
    }

@app.get("/health")
async def health_check():
    return {
        "status": "healthy",
        "timestamp": datetime.now().isoformat(),
        "service": "{{ service_name }}"
    }

@app.post("/items/", response_model=Item, status_code=status.HTTP_201_CREATED)
async def create_item(item: Item):
    logger.info(f"Item créé: {item.name}")
    return item

@app.get("/items/{item_id}", response_model=Item)
async def read_item(item_id: int):
    return Item(id=item_id, name=f"Item {item_id}")

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port={{ port }})
'''
    
    def _get_fastapi_crud_template(self) -> str:
        """Template CRUD FastAPI."""
        return self._get_fastapi_template()  # Version simplifiée
    
    def _get_database_model_template(self) -> str:
        """Template modèle de base de données."""
        return '''"""
Database Model - {{ model_name }}
"""

from sqlalchemy import Column, Integer, String, DateTime, Boolean
from sqlalchemy.ext.declarative import declarative_base
from datetime import datetime

Base = declarative_base()

class {{ model_name }}(Base):
    __tablename__ = '{{ model_name.lower() }}s'
    
    id = Column(Integer, primary_key=True, index=True)
    name = Column(String(100), nullable=False)
    created_at = Column(DateTime, default=datetime.utcnow)
    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)
    is_active = Column(Boolean, default=True)
    
    def to_dict(self):
        return {
            'id': self.id,
            'name': self.name,
            'created_at': self.created_at.isoformat() if self.created_at else None,
            'is_active': self.is_active
        }
'''
    
